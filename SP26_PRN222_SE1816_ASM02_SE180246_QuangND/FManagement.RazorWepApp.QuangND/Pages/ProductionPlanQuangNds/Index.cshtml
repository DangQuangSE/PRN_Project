@page
@model FManagement.RazorWepApp.QuangND.Pages.ProductionPlanQuangNds.IndexModel

@{
    ViewData["Title"] = "Production Plans";
}

<div class="container-fluid">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="bi bi-calendar-check text-primary"></i> Production Plans Management
                    </h2>
                    <p class="text-muted mb-0">Manage and track your production schedules</p>
                </div>
                <div>
                    <a asp-page="Create" class="btn btn-primary btn-lg shadow-sm">
                        <i class="bi bi-plus-circle"></i> Create New Plan
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter & Search Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-flag"></i> Plan Status
                    </label>
                    <select id="filterStatus" class="form-select">
                        <option value="">All Status</option>
                        <option value="Planned">Planned</option>
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar-event"></i> From Date
                    </label>
                    <input type="date" id="filterFromDate" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-calendar-event"></i> To Date
                    </label>
                    <input type="date" id="filterToDate" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-search"></i> Search
                    </label>
                    <input type="text" id="filterSearch" class="form-control" placeholder="Search notes, kitchen..." />
                </div>
                <div class="col-md-2">
                    <div class="d-grid gap-2 d-md-flex">
                        <button type="button" class="btn btn-primary" onclick="applyFilters()">
                            <i class="bi bi-search"></i> Search
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="clearFilters()">
                            <i class="bi bi-x-circle"></i> Clear
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="productionPlansTable">
                    <thead class="table-light">
                        <tr>
                            <th>Plan Date</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Status</th>
                            <th class="text-center">Priority</th>
                            <th class="text-center">Expected Qty</th>
                            <th class="text-center">Actual Qty</th>
                            <th>Notes</th>
                            <th>Modified By</th>
                            <th>Deleted</th>
                            <th>Kitchen</th>
                            <th>Order Item</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="productionPlansTableBody">
                @foreach (var item in Model.ProductionPlanQuangNd) {
                        <tr data-plan-id="@item.PlanId">
                            <td>
                                <i class="bi bi-calendar3 text-muted"></i>
                                @Html.DisplayFor(modelItem => item.PlanDate)
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.StartTime)</td>
                            <td>@Html.DisplayFor(modelItem => item.EndTime)</td>
                            <td>@Html.DisplayFor(modelItem => item.PlanStatus)</td>
                            <td class="text-center">@Html.DisplayFor(modelItem => item.PriorityLevel)</td>
                            <td class="text-center">
                                <strong class="text-primary">@Html.DisplayFor(modelItem => item.TotalExpectedQuantity)</strong>
                            </td>
                            <td class="text-center">
                                <strong class="text-success">@Html.DisplayFor(modelItem => item.ActualProducedQuantity)</strong>
                            </td>
                            <td>
                                <small class="text-muted">@Html.DisplayFor(modelItem => item.BatchNotes)</small>
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.LastModifiedBy)</td>
                            <td>@Html.DisplayFor(modelItem => item.IsDeleted)</td>
                            <td>
                                <i class="bi bi-building text-muted"></i>
                                @Html.DisplayFor(modelItem => item.Kitchen.KitchenName)
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.StoreOrderItem.OrderItemId)</td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-page="./Edit" asp-route-id="@item.PlanId"
                                       class="btn btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-page="./Details" asp-route-id="@item.PlanId"
                                       class="btn btn-outline-info" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-page="./Delete" asp-route-id="@item.PlanId"
                                       class="btn btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/productionPlanHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ProductionPlanDeleted", function (planId) {
            console.log("Production plan deleted: " + planId);
            
            const row = document.querySelector(`tr[data-plan-id="${planId}"]`);
            if (row) {
                row.style.opacity = '0.5';
                setTimeout(() => {
                    row.remove();
                    
                    const tbody = document.getElementById('productionPlansTableBody');
                    if (tbody.children.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="13" class="text-center py-5"><i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i><p class="text-muted mt-2">No production plans found.</p></td></tr>';
                    }
                }, 300);
            }
        });

        connection.start()
            .then(() => {
                console.log("SignalR Connected to Production Plan Hub");
            })
            .catch(err => {
                console.error("SignalR Connection Error: ", err);
                setTimeout(() => connection.start(), 5000);
            });

        connection.onreconnecting((error) => {
            console.log("SignalR Reconnecting...", error);
        });

        connection.onreconnected((connectionId) => {
            console.log("SignalR Reconnected. Connection ID: " + connectionId);
        });

        connection.onclose((error) => {
            console.log("SignalR Connection Closed", error);
            setTimeout(() => connection.start(), 5000);
        });
    </script>

    <script>
        // Client-side filtering
        function applyFilters() {
            const status = document.getElementById('filterStatus').value.toLowerCase();
            const fromDate = document.getElementById('filterFromDate').value;
            const toDate = document.getElementById('filterToDate').value;
            const search = document.getElementById('filterSearch').value.toLowerCase();
            const rows = document.querySelectorAll('#productionPlansTableBody tr[data-plan-id]');

            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                const rowStatus = (cells[3]?.textContent || '').trim().toLowerCase();
                const rowDate = (cells[0]?.textContent || '').trim();
                const rowText = row.textContent.toLowerCase();

                let show = true;

                // Status filter
                if (status && rowStatus !== status) show = false;

                // Date filters
                if (fromDate && rowDate) {
                    const d = new Date(rowDate);
                    if (!isNaN(d) && d < new Date(fromDate)) show = false;
                }
                if (toDate && rowDate) {
                    const d = new Date(rowDate);
                    if (!isNaN(d) && d > new Date(toDate)) show = false;
                }

                // Text search
                if (search && !rowText.includes(search)) show = false;

                row.style.display = show ? '' : 'none';
            });
        }

        function clearFilters() {
            document.getElementById('filterStatus').value = '';
            document.getElementById('filterFromDate').value = '';
            document.getElementById('filterToDate').value = '';
            document.getElementById('filterSearch').value = '';
            document.querySelectorAll('#productionPlansTableBody tr[data-plan-id]').forEach(row => {
                row.style.display = '';
            });
        }
    </script>

    <style>
        .table thead th {
            border-bottom: 2px solid #dee2e6;
            font-weight: 600;
            font-size: 0.875rem;
            padding: 0.75rem;
        }

        .table tbody td {
            padding: 0.75rem;
            vertical-align: middle;
        }

        .btn-group-sm > .btn {
            padding: 0.3rem 0.5rem;
            font-size: 0.85rem;
        }

        .badge {
            padding: 0.35em 0.6em;
            font-weight: 500;
        }
    </style>
}
