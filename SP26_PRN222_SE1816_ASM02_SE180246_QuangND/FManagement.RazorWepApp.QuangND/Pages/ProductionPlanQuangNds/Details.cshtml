@page
@model FManagement.RazorWepApp.QuangND.Pages.ProductionPlanQuangNds.DetailsModel

@{
    ViewData["Title"] = "Plan Details";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                <i class="bi bi-info-circle text-primary"></i> Plan Details
            </h2>
            <p class="text-muted">View production plan information</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row" id="ProductionPlanDetails">
                @Html.HiddenFor(model => model.ProductionPlanQuangNd.PlanId)
                <!-- Left Column -->
                <div class="col-md-6">
                    <h5 class="text-primary mb-3"><i class="bi bi-info-circle"></i> Basic Information</h5>
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width:40%"><i class="bi bi-calendar3"></i> Plan Date</th>
                                <td id="ProductionPlanQuangNd_PlanDate">@Html.DisplayFor(model => model.ProductionPlanQuangNd.PlanDate)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-clock"></i> Start Time</th>
                                <td id="ProductionPlanQuangNd_StartTime">@Html.DisplayFor(model => model.ProductionPlanQuangNd.StartTime)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-clock-fill"></i> End Time</th>
                                <td id="ProductionPlanQuangNd_EndTime">@Html.DisplayFor(model => model.ProductionPlanQuangNd.EndTime)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-flag"></i> Status</th>
                                <td id="ProductionPlanQuangNd_PlanStatus">@Html.DisplayFor(model => model.ProductionPlanQuangNd.PlanStatus)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-exclamation-triangle"></i> Priority</th>
                                <td id="ProductionPlanQuangNd_PriorityLevel">@Html.DisplayFor(model => model.ProductionPlanQuangNd.PriorityLevel)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-building"></i> Kitchen</th>
                                <td id="ProductionPlanQuangNd_KitchenName">@Html.DisplayFor(model => model.ProductionPlanQuangNd.Kitchen.KitchenName)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Right Column -->
                <div class="col-md-6">
                    <h5 class="text-primary mb-3"><i class="bi bi-gear"></i> Production Details</h5>
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width:40%"><i class="bi bi-box"></i> Expected Qty</th>
                                <td id="ProductionPlanQuangNd_TotalExpectedQuantity"><strong class="text-primary">@Html.DisplayFor(model => model.ProductionPlanQuangNd.TotalExpectedQuantity)</strong></td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-box-seam"></i> Actual Qty</th>
                                <td id="ProductionPlanQuangNd_ActualProducedQuantity"><strong class="text-success">@Html.DisplayFor(model => model.ProductionPlanQuangNd.ActualProducedQuantity)</strong></td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-cart"></i> Order Item</th>
                                <td id="ProductionPlanQuangNd_StoreOrderItemId">@Html.DisplayFor(model => model.ProductionPlanQuangNd.StoreOrderItem.OrderItemId)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-sticky"></i> Notes</th>
                                <td id="ProductionPlanQuangNd_BatchNotes">@Html.DisplayFor(model => model.ProductionPlanQuangNd.BatchNotes)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-person"></i> Modified By</th>
                                <td id="ProductionPlanQuangNd_LastModifiedBy">@Html.DisplayFor(model => model.ProductionPlanQuangNd.LastModifiedBy)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-trash"></i> Deleted</th>
                                <td id="ProductionPlanQuangNd_IsDeleted">@Html.DisplayFor(model => model.ProductionPlanQuangNd.IsDeleted)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <hr class="my-3" />

            <div class="d-flex justify-content-between">
                <a asp-page="./Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
                <a asp-page="./Edit" asp-route-id="@Model.ProductionPlanQuangNd.PlanId" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.min.js"></script>
    <script>
        "use strict";

        var connection = new signalR.HubConnectionBuilder().withUrl("/productionPlanHub").build();

        connection.start().then(function () {
            console.log("QuangND: Connected to the SignalR Hub");
        }).catch(function (err) {
            return console.error(err.toString());
        });

        // RECEIVER - Lắng nghe sự kiện cập nhật
        connection.on("Receiver_UpdateProductionPlan", function (item) {
            console.log(item);

            var currentPlanId = document.getElementById("ProductionPlanQuangNd_PlanId").value;

            if (currentPlanId == item.planId) {
                document.getElementById("ProductionPlanQuangNd_PlanDate").innerHTML = item.planDate || '';
                document.getElementById("ProductionPlanQuangNd_StartTime").innerHTML = item.startTime ? new Date(item.startTime).toLocaleString() : '';
                document.getElementById("ProductionPlanQuangNd_EndTime").innerHTML = item.endTime ? new Date(item.endTime).toLocaleString() : '';
                document.getElementById("ProductionPlanQuangNd_PlanStatus").innerHTML = item.planStatus || '';
                document.getElementById("ProductionPlanQuangNd_PriorityLevel").innerHTML = item.priorityLevel || '';
                document.getElementById("ProductionPlanQuangNd_KitchenName").innerHTML = item.kitchen?.kitchenName || '';
                document.getElementById("ProductionPlanQuangNd_TotalExpectedQuantity").innerHTML = item.totalExpectedQuantity || '';
                document.getElementById("ProductionPlanQuangNd_ActualProducedQuantity").innerHTML = item.actualProducedQuantity || '';
                document.getElementById("ProductionPlanQuangNd_StoreOrderItemId").innerHTML = item.storeOrderItemId || '';
                document.getElementById("ProductionPlanQuangNd_BatchNotes").innerHTML = item.batchNotes || '';
                document.getElementById("ProductionPlanQuangNd_LastModifiedBy").innerHTML = item.lastModifiedBy || '';
                document.getElementById("ProductionPlanQuangNd_IsDeleted").innerHTML = item.isDeleted;
            }
        });

        // RECEIVER - Lắng nghe sự kiện xóa
        connection.on("Receiver_DeleteProductionPlan", function (planId) {
            var currentPlanId = document.getElementById("ProductionPlanQuangNd_PlanId").value;

            if (currentPlanId == planId) {
                document.getElementById("ProductionPlanDetails").innerHTML = '<div class="alert alert-danger text-center"><i class="bi bi-exclamation-triangle"></i> This production plan has been deleted.</div>';
            } else {
                alert("Production plan #" + planId + " has been deleted.");
            }
        });
    </script>
}

