@page
@model FManagement.RazorWepApp.QuangND.Pages.ProductionPlanQuangNds.EditModel

@{
    ViewData["Title"] = "Edit Production Plan";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                <i class="bi bi-pencil-square text-primary"></i> Edit Production Plan
            </h2>
            <p class="text-muted">Update the production plan details</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="ProductionPlanQuangNd.PlanId" />
                
                <div class="row">
                    <!-- Left Column -->
                    <div class="col-md-6">
                        <h5 class="text-primary mb-3"><i class="bi bi-info-circle"></i> Basic Information</h5>
                        
                        <div class="mb-3">
                            <label asp-for="ProductionPlanQuangNd.StoreOrderItemId" class="form-label fw-semibold">
                                <i class="bi bi-cart"></i> Store Order Item <span class="text-danger">*</span>
                            </label>
                            <select asp-for="ProductionPlanQuangNd.StoreOrderItemId" class="form-select" asp-items="ViewBag.StoreOrderItemId">
                                <option value="">-- Select Order Item --</option>
                            </select>
                            <span asp-validation-for="ProductionPlanQuangNd.StoreOrderItemId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductionPlanQuangNd.KitchenId" class="form-label fw-semibold">
                                <i class="bi bi-building"></i> Central Kitchen <span class="text-danger">*</span>
                            </label>
                            <select asp-for="ProductionPlanQuangNd.KitchenId" class="form-select" asp-items="ViewBag.KitchenId">
                                <option value="">-- Select Kitchen --</option>
                            </select>
                            <span asp-validation-for="ProductionPlanQuangNd.KitchenId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductionPlanQuangNd.PlanDate" class="form-label fw-semibold">
                                <i class="bi bi-calendar"></i> Plan Date <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ProductionPlanQuangNd.PlanDate" class="form-control" />
                            <span asp-validation-for="ProductionPlanQuangNd.PlanDate" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProductionPlanQuangNd.StartTime" class="form-label fw-semibold">
                                    <i class="bi bi-clock"></i> Start Time
                                </label>
                                <input asp-for="ProductionPlanQuangNd.StartTime" class="form-control" />
                                <span asp-validation-for="ProductionPlanQuangNd.StartTime" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProductionPlanQuangNd.EndTime" class="form-label fw-semibold">
                                    <i class="bi bi-clock-fill"></i> End Time
                                </label>
                                <input asp-for="ProductionPlanQuangNd.EndTime" class="form-control" />
                                <span asp-validation-for="ProductionPlanQuangNd.EndTime" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="col-md-6">
                        <h5 class="text-primary mb-3"><i class="bi bi-gear"></i> Plan Details</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProductionPlanQuangNd.PlanStatus" class="form-label fw-semibold">
                                    <i class="bi bi-flag"></i> Status
                                </label>
                                <select asp-for="ProductionPlanQuangNd.PlanStatus" class="form-select" asp-items="ViewBag.PlanStatusList">
                                    <option value="">-- Select Status --</option>
                                </select>
                                <span asp-validation-for="ProductionPlanQuangNd.PlanStatus" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProductionPlanQuangNd.PriorityLevel" class="form-label fw-semibold">
                                    <i class="bi bi-exclamation-triangle"></i> Priority
                                </label>
                                <select asp-for="ProductionPlanQuangNd.PriorityLevel" class="form-select" asp-items="ViewBag.PriorityLevelList">
                                    <option value="">-- Select Priority --</option>
                                </select>
                                <span asp-validation-for="ProductionPlanQuangNd.PriorityLevel" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProductionPlanQuangNd.TotalExpectedQuantity" class="form-label fw-semibold">
                                    <i class="bi bi-box"></i> Expected Quantity
                                </label>
                                <input asp-for="ProductionPlanQuangNd.TotalExpectedQuantity" class="form-control" />
                                <span asp-validation-for="ProductionPlanQuangNd.TotalExpectedQuantity" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProductionPlanQuangNd.ActualProducedQuantity" class="form-label fw-semibold">
                                    <i class="bi bi-box-seam"></i> Produced Quantity
                                </label>
                                <input asp-for="ProductionPlanQuangNd.ActualProducedQuantity" class="form-control" />
                                <span asp-validation-for="ProductionPlanQuangNd.ActualProducedQuantity" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductionPlanQuangNd.BatchNotes" class="form-label fw-semibold">
                                <i class="bi bi-sticky"></i> Batch Notes
                            </label>
                            <textarea asp-for="ProductionPlanQuangNd.BatchNotes" class="form-control" rows="3" placeholder="Enter any notes..."></textarea>
                            <span asp-validation-for="ProductionPlanQuangNd.BatchNotes" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductionPlanQuangNd.LastModifiedBy" class="form-label fw-semibold">
                                <i class="bi bi-person"></i> Last Modified By
                            </label>
                            <input asp-for="ProductionPlanQuangNd.LastModifiedBy" class="form-control" />
                            <span asp-validation-for="ProductionPlanQuangNd.LastModifiedBy" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input class="form-check-input" asp-for="ProductionPlanQuangNd.IsDeleted" />
                            <label class="form-check-label" asp-for="ProductionPlanQuangNd.IsDeleted">
                                <i class="bi bi-trash"></i> Mark as Deleted
                            </label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <a asp-page="./Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-circle"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
