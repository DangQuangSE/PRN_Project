@page
@model FManagement.RazorWepApp.QuangND.Pages.ProductionPlanQuangNds.DeleteModel

@{
    ViewData["Title"] = "Delete Production Plan";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                <i class="bi bi-exclamation-triangle text-danger"></i> Delete Production Plan
            </h2>
            <p class="text-muted">Review the details below before confirming deletion</p>
        </div>
    </div>

    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger bg-opacity-10 text-danger fw-semibold">
            <i class="bi bi-exclamation-triangle"></i> Are you sure you want to delete this production plan?
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Left Column -->
                <div class="col-md-6">
                    <h5 class="text-primary mb-3"><i class="bi bi-info-circle"></i> Basic Information</h5>
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width:40%"><i class="bi bi-calendar3"></i> Plan Date</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.PlanDate)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-clock"></i> Start Time</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.StartTime)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-clock-fill"></i> End Time</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.EndTime)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-flag"></i> Status</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.PlanStatus)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-exclamation-triangle"></i> Priority</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.PriorityLevel)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-building"></i> Kitchen</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.Kitchen.KitchenName)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Right Column -->
                <div class="col-md-6">
                    <h5 class="text-primary mb-3"><i class="bi bi-gear"></i> Production Details</h5>
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width:40%"><i class="bi bi-box"></i> Expected Qty</th>
                                <td><strong class="text-primary">@Html.DisplayFor(model => model.ProductionPlanQuangNd.TotalExpectedQuantity)</strong></td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-box-seam"></i> Actual Qty</th>
                                <td><strong class="text-success">@Html.DisplayFor(model => model.ProductionPlanQuangNd.ActualProducedQuantity)</strong></td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-cart"></i> Order Item</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.StoreOrderItem.OrderItemId)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-sticky"></i> Notes</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.BatchNotes)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-person"></i> Modified By</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.LastModifiedBy)</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-trash"></i> Deleted</th>
                                <td>@Html.DisplayFor(model => model.ProductionPlanQuangNd.IsDeleted)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <hr class="my-3" />

            <div class="d-flex justify-content-between">
                <a asp-page="./Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
                <form method="post">
                    <input type="hidden" asp-for="ProductionPlanQuangNd.PlanId" />
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="bi bi-trash"></i> Confirm Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
