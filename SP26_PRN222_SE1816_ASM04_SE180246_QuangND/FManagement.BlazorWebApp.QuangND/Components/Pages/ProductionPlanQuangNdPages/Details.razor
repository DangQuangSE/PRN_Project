@page "/productionplanquangnds/details"
@using Microsoft.EntityFrameworkCore
@using FManagement.Entities.QuangND.Entities
@using FManagement.Services.QuangND
@inject IProductPlanQuangNDService ProductPlanService
@inject SystemAccountService SystemAccountService
@inject IDbContextFactory<FranchiseManagementContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>ProductionPlanQuangNd</h2>
    <hr />
    @if (productionplanquangnd is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">StoreOrderItem</dt>
            <dd class="col-sm-10">#@productionplanquangnd.StoreOrderItemId - @(productionplanquangnd.StoreOrderItem?.Product?.ProductName ?? "N/A")</dd>
            <dt class="col-sm-2">Kitchen</dt>
            <dd class="col-sm-10">@productionplanquangnd.Kitchen?.KitchenName</dd>
            <dt class="col-sm-2">PlanDate</dt>
            <dd class="col-sm-10">@productionplanquangnd.PlanDate</dd>
            <dt class="col-sm-2">StartTime</dt>
            <dd class="col-sm-10">@productionplanquangnd.StartTime</dd>
            <dt class="col-sm-2">EndTime</dt>
            <dd class="col-sm-10">@productionplanquangnd.EndTime</dd>
            <dt class="col-sm-2">PlanStatus</dt>
            <dd class="col-sm-10">@productionplanquangnd.PlanStatus</dd>
            <dt class="col-sm-2">PriorityLevel</dt>
            <dd class="col-sm-10">@productionplanquangnd.PriorityLevel</dd>
            <dt class="col-sm-2">TotalExpectedQuantity</dt>
            <dd class="col-sm-10">@productionplanquangnd.TotalExpectedQuantity</dd>
            <dt class="col-sm-2">ActualProducedQuantity</dt>
            <dd class="col-sm-10">@productionplanquangnd.ActualProducedQuantity</dd>
            <dt class="col-sm-2">BatchNotes</dt>
            <dd class="col-sm-10">@productionplanquangnd.BatchNotes</dd>
            <dt class="col-sm-2">LastModifiedBy</dt>
            <dd class="col-sm-10">@productionplanquangnd.LastModifiedBy (@LastModifiedByName)</dd>
            <dt class="col-sm-2">IsDeleted</dt>
            <dd class="col-sm-10">@productionplanquangnd.IsDeleted</dd>
        </dl>
        <div>
            <a href="@($"/productionplanquangnds/edit?planid={productionplanquangnd.PlanId}")">Edit</a> |
            <a href="@($"/productionplanquangnds")">Back to List</a>
        </div>
    }
</div>

@code {
    private ProductionPlanQuangNd? productionplanquangnd;
    private string? LastModifiedByName;

    [SupplyParameterFromQuery]
    private int PlanId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Check authentication
        var currentUserId = SystemAccountService.GetCurrentUserId();
        if (currentUserId == null || currentUserId <= 0)
        {
            NavigationManager.NavigateTo("/forbidden", forceLoad: true);
            return;
        }

        // Load data via Service
        productionplanquangnd = await ProductPlanService.GetByIdAysnc(PlanId);

        if (productionplanquangnd is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        // Load LastModifiedBy name
        if (productionplanquangnd.LastModifiedBy.HasValue)
        {
            using var context = DbFactory.CreateDbContext();
            var user = await context.SystemUserAccounts.FindAsync(productionplanquangnd.LastModifiedBy.Value);
            LastModifiedByName = user?.FullName ?? user?.UserName ?? "Unknown";
        }
    }
}
