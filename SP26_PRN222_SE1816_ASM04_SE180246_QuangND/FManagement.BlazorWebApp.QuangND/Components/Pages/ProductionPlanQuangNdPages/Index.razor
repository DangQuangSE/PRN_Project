@code {
    private IQueryable<ProductionPlanQuangNd>? _productionPlans;
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    private string? searchPlanStatus;
    private DateOnly? searchFromDate;
    private DateOnly? searchToDate;

    // applied variables for the Grid
    private string? appliedPlanStatus;
    private DateOnly? appliedFromDate;
    private DateOnly? appliedToDate;

    // We fetch EVERYTHING first then use QuickGrid filtering over the Queryable based on perform Search
    // Because that's how Bach's Grid works (in-memory filtering after db scan vs IQueryable from service).
    // Actually Bach uses normal filtering query. Let's do that!
    
    private void PerformSearch()
    {
        appliedPlanStatus = searchPlanStatus;
        appliedFromDate = searchFromDate;
        appliedToDate = searchToDate;
    }

    private IQueryable<ProductionPlanQuangNd> FilteredPlans
    {
        get
        {
            var result = _productionPlans ?? Enumerable.Empty<ProductionPlanQuangNd>().AsQueryable();

            if (!string.IsNullOrWhiteSpace(appliedPlanStatus))
            {
                result = result.Where(x => x.PlanStatus == appliedPlanStatus);
            }

            if (appliedFromDate.HasValue)
            {
                result = result.Where(x => x.PlanDate >= appliedFromDate.Value);
            }

            if (appliedToDate.HasValue)
            {
                result = result.Where(x => x.PlanDate <= appliedToDate.Value);
            }

            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Notice we don't kick user out here manually because AuthorizeView handles the UI state.
        try 
        {
            // Just get all because QuickGrid + FilteredPlans filters them
            var items = await _productPlanQuangNDService.SearchAsync(null, null, null, null);
            _productionPlans = items.AsQueryable();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading production plans: {ex.Message}");
            _productionPlans = Enumerable.Empty<ProductionPlanQuangNd>().AsQueryable();
        }
    }
}
