@page "/productionplanquangnds"
@attribute [Authorize]
@using FManagement.Services.QuangND
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.AspNetCore.Components.Authorization
@using FManagement.Entities.QuangND.Entities
@inject IProductPlanQuangNDService _productPlanQuangNDService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
<PageTitle>Index</PageTitle>

<h1>Index</h1>

<p>
    <a href="productionplanquangnds/create">Create New</a>
</p>

<!-- Search Form -->
<div class="mb-4">
    <EditForm Model="searchModel" OnSubmit="SearchData">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Plan Status</label>
                <InputSelect id="planstatus" @bind-Value="searchModel.PlanStatus" class="form-select">
                    <option value="">All</option>
                    <option value="Pending">Pending</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </InputSelect>
            </div>
            <div class="col-md-3">
                <label class="form-label">From Date</label>
                <InputDate @bind-Value="searchModel.FromDate" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To Date</label>
                <InputDate @bind-Value="searchModel.ToDate" class="form-control" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Search</button>
                <button type="button" class="btn btn-secondary" @onclick="ClearSearch">Clear</button>
            </div>
        </div>
    </EditForm>
</div>

<table class="table table-hover align-middle mb-0" id="productionPlansTable">
    <thead class="table-light">
        <tr>
            <th>PlanId</th>
            <th>Store Order Item</th>
            <th>Kitchen</th>
            <th>Plan Date</th>
            <th>Start Time</th>
            <th>End Time</th>
            <th>Plan Status</th>
            <th>Priority Level</th>
            <th>Total Expected Quantity</th>
            <th>Actual Produced Quantity</th>
            <th>Last Modified By</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="productionPlansTableBody">
        @if (ProductionPlanQuangNds != null)
        {
            @foreach (var plan in ProductionPlanQuangNds)
            {
                <tr>
                    <td>@plan.PlanId</td>
                    <td>@(plan.StoreOrderItem?.Product?.ProductName)</td>
                    <td>@(plan.Kitchen?.KitchenName)</td>
                    <td>@plan.PlanDate</td>
                    <td>@plan.StartTime</td>
                    <td>@plan.EndTime</td>
                    <td>@plan.PlanStatus</td>
                    <td>@plan.PriorityLevel</td>
                    <td>@plan.TotalExpectedQuantity</td>
                    <td>@plan.ActualProducedQuantity</td>
                    <td>@plan.LastModifiedBy</td>
                    <td>
                        <a href="@($"productionplanquangnds/edit?planid={plan.PlanId}")">Edit</a> |
                        <a href="@($"productionplanquangnds/details?planid={plan.PlanId}")">Details</a> |
                        <a href="@($"productionplanquangnds/delete?planid={plan.PlanId}")">Delete</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<!-- Pagination -->
<div class="row mt-3">
    <div class="col-12">
        <nav aria-label="Table pagination">
            <ul class="pagination justify-content-center" id="pagination"></ul>
        </nav>
    </div>
</div>

@code {
    private IQueryable<ProductionPlanQuangNd> ProductionPlanQuangNds = default!;
    private SearchModel searchModel = new();

    private class SearchModel
    {
        public string? PlanStatus { get; set; }
        public DateOnly? FromDate { get; set; }
        public DateOnly? ToDate { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        // Check authentication
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst("UserId")?.Value;
        
        if (!int.TryParse(userIdClaim, out int currentUserId) || currentUserId <= 0)
        {
            NavigationManager.NavigateTo("/forbidden", forceLoad: true);
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            var items = await _productPlanQuangNDService.SearchAsync(
                searchModel.PlanStatus,
                searchModel.FromDate,
                searchModel.ToDate,
                null
            );
            ProductionPlanQuangNds = items.AsQueryable();
        }
        catch (Exception ex)
        {
            throw new Exception("Error loading data: " + ex.Message);
        }
    }

    private async Task SearchData()
    {
        await LoadData();
    }

    private async Task ClearSearch()
    {
        searchModel = new SearchModel();
        await LoadData();
    }
}