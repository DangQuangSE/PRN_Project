@model FManagement.Entities.QuangND.Entities.ProductionPlanQuangNd

@{
    ViewData["Title"] = "Plan Details";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-1">
                <i class="bi bi-info-circle text-primary"></i> Plan Details
            </h2>
            <p class="text-muted">View production plan information</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row">
                <!-- Left Column -->
                <div class="col-md-6">
                    <h5 class="text-primary mb-3"><i class="bi bi-info-circle"></i> Basic Information</h5>
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width:40%"><i class="bi bi-calendar3"></i> Plan Date</th>
                                <td>@Model.PlanDate.ToString("MMM dd, yyyy")</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-clock"></i> Start Time</th>
                                <td>@(Model.StartTime?.ToString("HH:mm") ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-clock-fill"></i> End Time</th>
                                <td>@(Model.EndTime?.ToString("HH:mm") ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-flag"></i> Status</th>
                                <td>
                                    @{
                                        var statusClass = Model.PlanStatus switch
                                        {
                                            "Pending" => "warning",
                                            "In Progress" => "info",
                                            "Processing" => "info",
                                            "Completed" => "success",
                                            "Cancelled" => "danger",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@statusClass">@(Model.PlanStatus ?? "N/A")</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-exclamation-triangle"></i> Priority</th>
                                <td>
                                    @{
                                        var priorityValue = Model.PriorityLevel ?? 0;
                                        var priorityBadge = priorityValue switch
                                        {
                                            2 => "danger",
                                            1 => "warning",
                                            _ => "secondary"
                                        };
                                        var priorityText = priorityValue switch
                                        {
                                            2 => "High",
                                            1 => "Medium",
                                            0 => "Low",
                                            _ => "N/A"
                                        };
                                    }
                                    <span class="badge bg-@priorityBadge">@priorityText</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-building"></i> Kitchen</th>
                                <td>@(Model.Kitchen?.KitchenName ?? "N/A")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Right Column -->
                <div class="col-md-6">
                    <h5 class="text-primary mb-3"><i class="bi bi-gear"></i> Production Details</h5>
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width:40%"><i class="bi bi-box"></i> Expected Qty</th>
                                <td><strong class="text-primary">@(Model.TotalExpectedQuantity ?? 0)</strong></td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-box-seam"></i> Actual Qty</th>
                                <td><strong class="text-success">@(Model.ActualProducedQuantity ?? 0)</strong></td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-cart"></i> Order Item</th>
                                <td>@(Model.StoreOrderItem?.OrderItemId.ToString() ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-sticky"></i> Notes</th>
                                <td>@(Model.BatchNotes ?? "-")</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-person"></i> Modified By</th>
                                <td>@(Model.LastModifiedBy?.ToString() ?? "-")</td>
                            </tr>
                            <tr>
                                <th class="text-muted"><i class="bi bi-trash"></i> Deleted</th>
                                <td>
                                    @if (Model.IsDeleted) {
                                        <span class="badge bg-danger">Yes</span>
                                    } else {
                                        <span class="badge bg-success">No</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <hr class="my-3" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
                <a asp-action="Edit" asp-route-id="@Model?.PlanId" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
        </div>
    </div>
</div>
